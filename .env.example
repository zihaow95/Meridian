# Project Meridian development environment template.
# Copy to .env for local development. Contains development placeholders only:
# never put real credentials here. .env is git-ignored.

# --- Django ---
# Dev-only secret. Production injects a strong secret via the environment.
DJANGO_SECRET_KEY=dev-insecure-secret-key-do-not-use-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- MySQL (served by deploy/compose/compose.dev.yml) ---
# Root password is only used to initialize the container on first run.
MYSQL_ROOT_PASSWORD=dev-root-password
MYSQL_DATABASE=meridian
MYSQL_USER=meridian
MYSQL_PASSWORD=meridian
# Application connects from the host to the published port.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# Django creates and tears down this dedicated test database.
MYSQL_TEST_DATABASE=meridian_test

# --- Redis (served by deploy/compose/compose.dev.yml) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Host port bindings for Compose services (bound to loopback only) ---
MYSQL_PUBLISHED_PORT=3306
REDIS_PUBLISHED_PORT=6379
